# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app

# Database pool (tune for your expected concurrency)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Auth — generate in production: openssl rand -hex 32
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
LLM_TIMEOUT_SECONDS=60.0

# CORS — restrict to specific origins in production, e.g. ["https://myapp.com"]
CORS_ORIGINS=["*"]

# Rate limiting (slowapi format: "N/period" — e.g. "20/minute", "100/hour")
RATE_LIMIT_LLM=20/minute

# Development mode — set true for hot reload (uvicorn --reload)
# DEV_MODE=true
